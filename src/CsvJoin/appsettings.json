{
  "Sources": {
    "left": {
      "FilePath": "sample-data\\left.csv",
      "Delimiter": ","
    },
    "right": {
      "FilePath": "sample-data\\right.csv",
      "Delimiter": ","
    }
  },
  "Query": "SELECT left.Id, left.Name, right.Status AS TargetStatus FROM left LEFT JOIN right ON left.Id = right.Id",
